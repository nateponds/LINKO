# Frontend (Vite) dev config. Copy to .env for local overrides.

# Port the Vite dev-server proxies /api to. Must match backend/.env's PORT.
# Default 5001 (macOS AirPlay Receiver squats 5000). Change both together.
VITE_BACKEND_PORT=5001

# Mapbox access token for the location picker (Settings, branch management).
# Client-exposed publishable token (pk.*): env-only — NEVER commit a real
# value — and restrict it to your domains in the Mapbox dashboard (token URL
# restrictions) before any production deploy. Leave unset to skip the map:
# every page falls back to the numeric coordinate inputs and stays usable.
# VITE_MAPBOX_TOKEN=
